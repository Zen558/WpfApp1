<Window x:Class="CalculatorApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Простой калькулятор"
        Height="420"
        Width="360"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Icon="Images/CalculatorIcon.ico">
	<Grid Margin="10">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="*"/>
		</Grid.RowDefinitions>

		<TextBlock Grid.Row="0"
               Text="Калькулятор"
               FontSize="24"
               FontWeight="Bold"
               HorizontalAlignment="Center"
               Margin="0,0,0,20"/>

		<StackPanel Grid.Row="1" Margin="0,0,0,10">
			<TextBlock Text="Первое число:" FontSize="14" Margin="0,0,0,5"/>
			<TextBox x:Name="FirstNumberTextBox" FontSize="16" Padding="5" Height="35"/>
		</StackPanel>

		<StackPanel Grid.Row="2" Margin="0,0,0,10">
			<TextBlock Text="Второе число:" FontSize="14" Margin="0,0,0,5"/>
			<TextBox x:Name="SecondNumberTextBox" FontSize="16" Padding="5" Height="35"/>
		</StackPanel>

		<StackPanel Grid.Row="3" Margin="0,0,0,15">
			<TextBlock Text="Выберите операцию:" FontSize="14" Margin="0,0,0,10"/>
			<UniformGrid Rows="1" Columns="5">
				
				<Button x:Name="AddButton" Content="+" FontSize="20" Margin="0,0,5,0" Height="50" Click="AddButton_Click" Background="#FFE0F7FA"/>
				<Button x:Name="SubtractButton" Content="-" FontSize="20" Margin="0,0,5,0" Height="50" Click="SubtractButton_Click" Background="#FFE0F7FA"/>
				<Button x:Name="MultiplyButton" Content="×" FontSize="20" Margin="0,0,5,0" Height="50" Click="MultiplyButton_Click" Background="#FFE0F7FA"/>
				<Button x:Name="DivideButton" Content="÷" FontSize="20" Height="50" Click="DivideButton_Click" Background="#FFE0F7FA"/>
				<Button x:Name="PowerButton" Content="^" FontSize="20" Margin="0,0,0,0" Height="50" Click="PowerButton_Click" Background="#FFE0F7FA"/>
			</UniformGrid>
		</StackPanel>

		<StackPanel Grid.Row="4" Margin="0,0,0,10">
			<TextBlock Text="Результат:" FontSize="14" Margin="0,0,0,5"/>
			<TextBox x:Name="ResultTextBox" FontSize="18" Padding="5" Height="40" IsReadOnly="True" Background="LightYellow" FontWeight="Bold"/>
		</StackPanel>

		<Button Grid.Row="5" Content="Очистить" FontSize="16" Height="40" VerticalAlignment="Top" Click="ClearButton_Click"/>
	</Grid>
</Window>
